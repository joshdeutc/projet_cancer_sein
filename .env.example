# Configuration du pipeline GMIC
# Copiez ce fichier en .env et remplissez vos valeurs

# ── Kaggle ────────────────────────────────────────────────────────────────────
KAGGLE_USERNAME=votre_username
KAGGLE_KEY=votre_api_key

# ── Chemins ───────────────────────────────────────────────────────────────────
# Dossier contenant les images (DICOM ou PNG) et le CSV
INPUT_DIR=data

# Dossier de sortie (predictions, images croppees, etc.)
OUTPUT_DIR=output

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Format des images d entree : auto, dicom, png
INPUT_FORMAT=auto

# Nombre de processus pour le crop et get_optimal_centers
NUM_PROCESSES=4
